# ─────────────────────────────────────────────────────────────
#  .env.example  —  이 파일을 복사해서 .env 로 저장한 뒤 값을 채우세요.
#  Streamlit Cloud 배포 시: Settings > Secrets 에 동일 키-값 입력
# ─────────────────────────────────────────────────────────────

# ── Fear & Greed Index ────────────────────────────────────────
# 비워두면 alternative.me 무료 API 자동 사용 (키 불필요)
# RapidAPI 유료 플랜을 쓸 경우 아래 키를 입력
RAPIDAPI_KEY=

# Fear & Greed 점수를 직접 고정하고 싶을 때 (0~100 정수)
# 입력하면 API 호출 없이 이 값을 사용
# FEAR_GREED_OVERRIDE=72

# ── News API (미래 뉴스 섹션용) ───────────────────────────────
# https://newsapi.org 에서 무료 키 발급
NEWS_API_KEY=

# ── Alpha Vantage (yfinance 대체 옵션) ───────────────────────
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=
